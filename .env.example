# ─────────────────────────────────────────────
# Footactiq — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# ── MongoDB Atlas ──────────────────────────────
# 1. Go to https://cloud.mongodb.com
# 2. Create a free M0 cluster
# 3. Click "Connect" → "Drivers" → copy the connection string
# 4. Replace <password> and <dbname> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/footactiq?retryWrites=true&w=majority

# ── ZeptoMail ──────────────────────────────────
# 1. Go to https://zeptomail.zoho.com
# 2. Create a Mail Agent
# 3. Add & verify your sending domain
# 4. Copy the Send Mail Token from the Mail Agent page
ZEPTOMAIL_TOKEN=Zoho-enczapikey xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sender identity ────────────────────────────
# Must match your verified ZeptoMail sending domain
FROM_EMAIL=hello@footactiq.com
FROM_NAME=Footactiq

# ── Admin notifications ────────────────────────
# Get notified every time someone joins the waitlist
ADMIN_EMAIL=admin@footactiq.com

# ── App URL (used in emails) ───────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
